# 复制为 .env 或在 PowerShell 中 set 同名变量（勿提交含密钥的 .env）

# 网关监听
GATEWAY_BIND_HOST=0.0.0.0
GATEWAY_BIND_PORT=9090

# 聚宽 / 公网调用者须带请求头 X-API-Key；单机可设短密钥便于测试
GATEWAY_API_KEY=

# Windows Agent 地址（单机默认本机）
AGENT_BASE_URL=http://127.0.0.1:9780

# 与 windows Agent 的 INTERNAL_API_KEY 一致；转发时自动带 X-Internal-Key
INTERNAL_API_KEY=

# 网关幂等缓存秒数，0=关闭（仍依赖 Agent 侧幂等）
GATEWAY_IDEM_TTL_SEC=86400

# AGENT_HTTP_TIMEOUT_SEC=30
