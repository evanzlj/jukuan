# 复制为 .env 或直接在「系统环境变量」中设置（勿将真实 .env 提交 Git）

# QMT 安装目录下的 bin.x64（xtquant 在 bin.x64\Lib\site-packages\xtquant）
QMT_BIN_DIR=D:\券商QMT路径\bin.x64

# 华鑫 QMT 实盘示例（请按本机安装路径修改）：
# QMT_BIN_DIR=D:\迅投极速策略交易系统交易终端 华鑫证券QMT实盘\bin.x64
# QMT_USERDATA_MINI=D:\迅投极速策略交易系统交易终端 华鑫证券QMT实盘\userdata_mini

# XtQuantTrader 第一个参数：mini 客户端下的 userdata 目录（华鑫为 userdata_mini）
QMT_USERDATA_MINI=D:\券商QMT路径\userdata_mini

# 资金账号
QMT_ACCOUNT_ID=

# 可选：多实例时修改，避免冲突
QMT_SESSION_ID=135791

# 监听（建议配合防火墙，仅允许 Tailscale 网段访问本机端口）
AGENT_BIND_HOST=0.0.0.0
AGENT_BIND_PORT=9780

# 与南京网关约定的密钥；请求头 X-Internal-Key
INTERNAL_API_KEY=

# 可选
# DEFAULT_STRATEGY_NAME=jq_relay
# CONNECT_ON_STARTUP=0
